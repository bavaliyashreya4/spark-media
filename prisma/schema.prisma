generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DATABASE_URL_UNPOOLED")
}

model Contact {
  id          String   @id @default(cuid())
  name        String
  email       String
  projectType String
  message     String
  createdAt   DateTime @default(now())
}
